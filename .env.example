# ============================================================
# Shadow-Radar :: Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# This tool is READ-ONLY analytics — no private keys needed.
# ============================================================

# Yellowstone gRPC endpoint (must support 24h replay slots)
YELLOWSTONE_GRPC_HTTP=https://grpc.ny.shyft.to
YELLOWSTONE_GRPC_TOKEN=YOUR_GRPC_TOKEN

# Standard Solana RPC (used for slot-time lookups)
RPC_HTTP=https://rpc.shyft.to?api_key=YOUR_API_KEY
