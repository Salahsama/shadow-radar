# =============================================================================
# Shadow-Radar — .gitignore
# =============================================================================

# --- Secrets & Environment ---
.env
*.env.*
!.env.example

# --- Rust Build Artifacts ---
/target/

# --- SQLite Databases (live mode output) ---
*.db
*.db-shm
*.db-wal

# --- Logs ---
*.log
logs/

# --- Output / Results (replay mode) ---
alpha_wallets.json
*.json
!*example*.json
!*template*.json

# --- IDE & Editor ---
.vscode/
.idea/
*.iml
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini
